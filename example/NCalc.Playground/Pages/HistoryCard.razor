<div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between gap-2">
        <h2 class="h6 fw-semibold mb-0 d-inline-flex align-items-center gap-2">
            <i class="bi bi-clock-history" aria-hidden="true"></i>
            <span>History</span>
        </h2>
        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="OnClear" disabled="@(History.Count == 0)">
            <span>Clear history</span>
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive playground-table">
            <table class="table table-sm table-hover align-middle mb-0 history-table">
                <thead>
                    <tr>
                        <th scope="col">Expression</th>
                        <th scope="col">Result</th>
                        <th class="type-column" scope="col">Type</th>
                    </tr>
                </thead>
                <tbody>
                    @if (History.Count == 0)
                    {
                        <tr>
                            <td class="text-body-secondary py-4 text-center" colspan="3">No evaluations yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in History)
                        {
                            <tr @key="item"
                                class="history-row @(ReferenceEquals(item, SelectedItem) ? "table-active" : "")"
                                @onclick="() => OnApply.InvokeAsync(item)">
                                <td class="text-truncate history-expression">
                                    @if (!string.Equals(item.Expression, item.OriginalExpressionString, StringComparison.InvariantCultureIgnoreCase))
                                    {
                                        <span
                                            data-bs-toggle="tooltip"
                                            data-bs-placement="top"
                                            data-bs-container="body"
                                            title="@item.OriginalExpressionString"
                                            >@item.Expression</span>
                                    }
                                    else
                                    {
                                        @item.Expression
                                    }
                                </td>
                                <td class="text-truncate">
                                    @switch (item.Result)
                                    {
                                        case true:
                                            <span class="font-monospace text-success">True</span>
                                            break;
                                        case false:
                                            <span class="font-monospace text-danger">False</span>
                                            break;
                                        case null:
                                            <span class="font-monospace text-muted">null</span>
                                            break;
                                        case string when !item.HasError:
                                            <span class="font-monospace text-muted">"@item.Result"</span>
                                            break;
                                        case IFormattable formattable:
                                            @formattable.ToString(null, CultureInfo.InvariantCulture)
                                            break;
                                        default:
                                            @item.Result?.ToString()
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (item.HasError)
                                    {
                                        <span class="badge text-bg-danger"
                                              data-bs-toggle="tooltip"
                                              data-bs-placement="top"
                                              data-bs-container="body"
                                              title="@item.ReturnType.Name">
                                            Exception
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="font-monospace">@item.ReturnType.Name</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public IReadOnlyList<EvaluationHistoryItem> History { get; set; } = [];

    [Parameter]
    public EvaluationHistoryItem? SelectedItem { get; set; }

    [Parameter]
    public EventCallback<EvaluationHistoryItem> OnApply { get; set; }

    [Parameter]
    public EventCallback OnClear { get; set; }
}
