@using NCalc.Playground.Extensions
<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <h2 class="h6 fw-semibold mb-0 d-inline-flex align-items-center gap-2">
            <i class="bi bi-pencil" aria-hidden="true"></i>
            <span>Expression</span>
        </h2>
    </div>

    <div class="card-body">
        <EditForm Model="this" OnSubmit="HandleSubmit">
            <div class="d-flex flex-column flex-sm-row gap-2 expression-row">
                <InputText id="expressionInput"
                           class="@ExpressionInputClass"
                           @bind-Value="_currentExpressionText"
                           autocomplete="off"
                           aria-label="Expression"
                           aria-invalid="@HasError" />

                <div class="btn-group expression-actions">
                    <button class="btn btn-primary fw-semibold px-4" type="submit">
                        <span class="bi bi-play-circle-fill bi-lg"></span>
                        Evaluate
                    </button>
                    <button type="button"
                            class="btn btn-primary dropdown-toggle dropdown-toggle-split"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="outside"
                            aria-expanded="false">
                        <span class="visually-hidden">Toggle options dropdown</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end p-2 shadow">
                        @foreach (var option in SelectableOptions)
                        {
                            <li>
                                <label class="dropdown-item d-flex align-items-center gap-2 rounded-2 mb-0 expression-option-item">
                                    <input class="form-check-input m-0"
                                           type="checkbox"
                                           checked="@HasOption(option)"
                                           @onchange="eventArgs => ToggleOption(option, eventArgs)" />
                                    <span>@option.GetDisplayName()</span>
                                </label>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private static readonly ExpressionOptions[] SelectableOptions =
        Enum.GetValues<ExpressionOptions>()
            .Where(option => option != ExpressionOptions.None)
            .OrderBy(option => option.ToString())
            .ToArray();

    [Parameter]
    public string ExpressionText { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnEvaluate { get; set; }

    [Parameter]
    public ExpressionOptions SelectedOptions { get; set; }

    [Parameter]
    public EventCallback<ExpressionOptions> SelectedOptionsChanged { get; set; }

    [Parameter]
    public bool HasError { get; set; }

    private string _currentExpressionText = string.Empty;
    private string _previousExpressionText = string.Empty;

    private string ExpressionInputClass => HasError
        ? "form-control font-monospace is-invalid"
        : "form-control font-monospace";

    protected override void OnParametersSet()
    {
        if (ExpressionText == _previousExpressionText)
            return;

        _currentExpressionText = ExpressionText;
        _previousExpressionText = ExpressionText;
    }

    private bool HasOption(ExpressionOptions option) => SelectedOptions.HasFlag(option);

    private async Task ToggleOption(ExpressionOptions option, ChangeEventArgs eventArgs)
    {
        var isChecked = eventArgs.Value is bool value
            ? value
            : bool.TryParse(eventArgs.Value?.ToString(), out var parsedValue) && parsedValue;
        var updatedOptions = isChecked
            ? SelectedOptions | option
            : SelectedOptions & ~option;

        if (updatedOptions == SelectedOptions)
            return;

        SelectedOptions = updatedOptions;
        await SelectedOptionsChanged.InvokeAsync(updatedOptions);
    }

    private Task HandleSubmit(EditContext _)
    {
        return OnEvaluate.InvokeAsync(_currentExpressionText);
    }
}
