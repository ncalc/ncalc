<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NCalc.Playground.ViewModels"
             x:Class="NCalc.Playground.Views.ExpressionEditorView"
             x:DataType="vm:ExpressionEditorViewModel">
    <Border Padding="8"
            BorderBrush="{DynamicResource ControlDarkBrush}"
            BorderThickness="1"
            Background="{DynamicResource ControlBrush}">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock FontWeight="Bold"
                       VerticalAlignment="Center"
                       Text="Expression" />
            <TextBox Grid.Column="1"
                     Height="32"
                     AcceptsReturn="False"
                     TextWrapping="NoWrap"
                     VerticalContentAlignment="Center"
                     Text="{Binding ExpressionText, Mode=TwoWay}" />
        </Grid>
    </Border>
</UserControl>
