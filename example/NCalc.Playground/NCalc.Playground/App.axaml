<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:classic="clr-namespace:Classic.Avalonia.Theme;assembly=Classic.Avalonia.Theme"
             x:Class="NCalc.Playground.App"
             RequestedThemeVariant="{x:Static ClassicTheme.Classic}">
    <Application.Styles>
        <classic:ClassicTheme FontAliasing="True" />
        
        <StyleInclude Source="avares://Classic.Avalonia.Theme.DataGrid/Classic.axaml" />
    </Application.Styles>
</Application>
